# CPUSTACK 主计算节点环境变量配置示例
# 复制为 .env 并按需修改；环境变量优先级高于 YAML 配置文件

# ===== 基本配置 =====
# 是否开启调试模式（开启后输出更详细日志，生产环境建议关闭）
CPUSTACK_DEBUG=true
# 数据目录（存储数据库、模型缓存、知识库等运行时数据）
CPUSTACK_DATA_DIR=./data
# 主节点服务监听地址（0.0.0.0 表示监听所有网卡，便于子节点接入）
CPUSTACK_HOST=0.0.0.0
# 主节点服务监听端口（对外提供 API 与管理界面）
CPUSTACK_PORT=8081
# JWT 签名密钥（生产环境务必修改为 32 字节以上的随机字符串）
CPUSTACK_SECRET_KEY=please-change-this-to-a-32+bytes-random-secret-key

# ===== 数据库配置 =====
# 异步数据库连接串（默认使用 SQLite，生产环境推荐 PostgreSQL）
CPUSTACK_DB_URL=sqlite+aiosqlite:///./data/cpustack.db
# 同步数据库连接串（用于 Alembic 迁移与初始化脚本）
CPUSTACK_DB_URL_SYNC=sqlite:///./data/cpustack.db

# ===== 集群 Token（主子节点必须一致，用于 Worker 注册鉴权）=====
CPUSTACK_WORKER_TOKEN=cpustack-cluster-token

# ===== Worker 配置（主节点内嵌 Worker，单机模式可直接推理）=====
# 主节点服务对外访问地址（子节点通过此地址注册，请使用实际可达 IP）
CPUSTACK_SERVER_URL=http://127.0.0.1:8081
# Worker HTTP 服务端口（子节点状态预览页 + 本地任务通信）
CPUSTACK_WORKER_PORT=30080

# ===== 调度配置 =====
# 调度器扫描间隔（秒，每隔多久扫描待部署实例并分配 Worker）
CPUSTACK_SCHEDULER_INTERVAL_SECONDS=30
# Worker 心跳超时时间（秒，超过该时间未收到心跳则判定为离线）
CPUSTACK_WORKER_HEARTBEAT_TIMEOUT_SECONDS=120

# ===== 模型存储 =====
# 模型缓存目录（下载的模型权重存放位置）
CPUSTACK_MODEL_CACHE_DIR=./data/cache
# HuggingFace 国内镜像（加速模型下载，留空则使用官方源）
CPUSTACK_HUGGINGFACE_MIRROR=https://hf-mirror.com

# ===== 服务端口范围（推理后端监听端口池）=====
# 推理服务端口范围起点（每个部署的实例占用一个端口）
CPUSTACK_SERVICE_PORT_RANGE_START=40000
# 推理服务端口范围终点
CPUSTACK_SERVICE_PORT_RANGE_END=41000

# ===== 局域网子节点发现（UDP 广播）=====
# 子节点发现服务监听端口（主子节点必须一致）
CPUSTACK_DISCOVERY_PORT=30090
# 局域网扫描超时时间（秒，扫描子节点时的等待时长）
CPUSTACK_DISCOVERY_SCAN_TIMEOUT=5
