# CPUSTACK 子计算节点环境变量配置示例
# 复制为 .env 并按需修改；子节点仅保留 Worker 相关配置

# ===== 基本配置 =====
# 是否开启调试模式（生产环境建议关闭以减少日志量）
CPUSTACK_DEBUG=false
# 数据目录（存储本地缓存等运行时数据）
CPUSTACK_DATA_DIR=./data
# 日志级别（DEBUG/INFO/WARNING/ERROR）
CPUSTACK_LOG_LEVEL=INFO

# ===== 集群 Token（必须与主节点保持一致，用于注册鉴权）=====
CPUSTACK_WORKER_TOKEN=cpustack-cluster-token

# ===== 主节点连接配置 =====
# 主节点服务地址（请替换为主节点实际 IP，不要使用 127.0.0.1 或 localhost）
CPUSTACK_SERVER_URL=http://主节点IP:8081
# Worker 名称（留空则自动使用主机名，便于在主节点界面识别）
CPUSTACK_WORKER_NAME=
# Worker HTTP 服务端口（子节点状态预览页 + 本地任务通信）
CPUSTACK_WORKER_PORT=30080

# ===== 模型存储 =====
# 模型缓存目录（下载的模型权重存放位置）
CPUSTACK_MODEL_CACHE_DIR=./data/cache
# HuggingFace 国内镜像（加速模型下载，留空则使用官方源）
CPUSTACK_HUGGINGFACE_MIRROR=https://hf-mirror.com

# ===== 局域网子节点发现（UDP 广播）=====
# 子节点发现服务监听端口（需与主节点保持一致）
CPUSTACK_DISCOVERY_PORT=30090
