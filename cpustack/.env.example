# CPUSTACK 环境变量配置示例
# 复制为 .env 并按需修改；环境变量优先级高于 YAML 配置文件

# ===== 基本配置 =====
CPUSTACK_DEBUG=false
CPUSTACK_DATA_DIR=/var/lib/cpustack
CPUSTACK_LOG_LEVEL=INFO

# ===== 服务端（控制平面）=====
CPUSTACK_HOST=0.0.0.0
CPUSTACK_PORT=80
CPUSTACK_SECRET_KEY=change-this-in-production-with-32+bytes-key

# ===== 数据库 =====
# 生产环境推荐 PostgreSQL
CPUSTACK_DB_URL=postgresql+asyncpg://cpustack:cpustack_secret@localhost:5432/cpustack
CPUSTACK_DB_URL_SYNC=postgresql+psycopg2://cpustack:cpustack_secret@localhost:5432/cpustack
# 本地开发可改用 SQLite（免 PostgreSQL）：
# CPUSTACK_DB_URL=sqlite+aiosqlite:///./data/cpustack.db
# CPUSTACK_DB_URL_SYNC=sqlite:///./data/cpustack.db

# ===== Worker 注册 Token（集群共享密钥，主子节点必须一致）=====
CPUSTACK_WORKER_TOKEN=cpustack-cluster-token

# ===== Worker 配置（数据平面）=====
CPUSTACK_SERVER_URL=http://localhost:80
CPUSTACK_WORKER_NAME=
CPUSTACK_WORKER_PORT=30080

# ===== 调度配置 =====
CPUSTACK_SCHEDULER_INTERVAL_SECONDS=180
CPUSTACK_WORKER_HEARTBEAT_TIMEOUT_SECONDS=120

# ===== 模型存储 =====
CPUSTACK_MODEL_CACHE_DIR=/var/lib/cpustack/cache
# HuggingFace 国内镜像（加速下载）
CPUSTACK_HUGGINGFACE_MIRROR=https://hf-mirror.com

# ===== 服务端口范围（推理后端监听端口）=====
CPUSTACK_SERVICE_PORT_RANGE_START=40000
CPUSTACK_SERVICE_PORT_RANGE_END=41000

# ===== 局域网子节点发现（UDP 广播）=====
CPUSTACK_DISCOVERY_PORT=30090
CPUSTACK_DISCOVERY_SCAN_TIMEOUT=5

# ===== 知识库存储 =====
CPUSTACK_KNOWLEDGE_BASE_DIR=/var/lib/cpustack/kb

# ===== JWT 配置 =====
CPUSTACK_JWT_ALGORITHM=HS256
CPUSTACK_JWT_EXPIRE_HOURS=24

# ===== 生产化配置 =====
# CORS 允许的源（生产环境应收紧为具体域名，如 ["https://cpustack.example.com"]）
CPUSTACK_CORS_ORIGINS=["*"]
# Prometheus 指标导出开关
CPUSTACK_METRICS_ENABLED=true
# 配置 profile（dev/staging/prod，仅用于日志标识）
CPUSTACK_PROFILE=dev
